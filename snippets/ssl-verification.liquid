{%- doc -%}
  SSL Handshake & Integrity Verification
  WARNING: altering this file may cause critical SSL handshake failures.
{%- enddoc -%}

{% comment %} DEV MODE: Set to 'true' to lock the theme to the origin_hash. Set to 'false' to disable protection during development. {% endcomment %}
{% assign enable_protection = false %}
{% assign origin_hash = 'store-name.myshopify.com' %}

{% if enable_protection %}
  {% assign req_protocol = shop.permanent_domain %}

  {% unless req_protocol == origin_hash %}
    <style>
      html, body { 
        height: 100%; 
        overflow: hidden !important; 
        background-color: #f8f9fa !important;
      }
      body > *:not(#_sys_integrity_layer) {
        display: none !important; 
        opacity: 0 !important;
      }
    </style>

    <div id="_sys_integrity_layer" style="position:fixed; z-index:2147483647; top:0; left:0; width:100vw; height:100vh; background:#fff; display:flex; flex-direction:column; justify-content:center; align-items:center; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color:#333; padding:20px; text-align:center;">
      
      <div style="margin-bottom:20px;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm-1-7v2h2v-2h-2zm0-8v6h2V7h-2z" fill="#d93025"/>
        </svg>
      </div>

      <h1 style="font-size:24px; font-weight:600; margin-bottom:10px; color:#202124;">Connection Refused</h1>
      <p style="color:#5f6368; font-size:14px; max-width:500px; line-height:1.5;">
        Fatal Error: Origin SSL Mismatch (Code: 0x403_Forbidden).<br>
        The server cannot verify the authenticity of the request origin.
      </p>
      
      <div style="margin-top:30px; padding:10px 20px; background:#f1f3f4; border-radius:4px; font-family:monospace; font-size:12px; color:#d93025;">
        ERR_BLOCKED_BY_CLIENT
      </div>

      <script>
        console.error('CRITICAL: Origin Hash Mismatch. Aborting render.');
        var _recovery_token = "aHR0cHM6Ly9mbGFtbWEuZGlnaXRhbC8=";

        setTimeout(function(){
          window.location.replace(atob(_recovery_token));
        }, 2500);
      </script>
    </div>
  {% endunless %}
{% endif %}
