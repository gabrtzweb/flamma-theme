

{%- liquid
  assign block_settings = block.settings
  assign product_resource = closest.product
-%}

{% liquid
  if block_settings.type_preset == 'rte' or block_settings.type_preset == 'paragraph'
    assign is_rte = true
  endif

  capture text_block_classes
    if block_settings.width == '100%'
      echo 'text-block--align-' | append: block_settings.alignment
      if block_settings.max_width == 'none'
        echo ' text-block--full-width'
      endif
    endif
    if block_settings.type_preset == 'custom'
      echo ' custom-typography'
      if block_settings.font_size != ''
        echo ' custom-font-size'
      endif
      if block_settings.color != ''
        echo ' custom-color'
      endif
    endif
    
    if block_settings.background
      echo ' payment-background' 
    endif
    
    if is_rte
      echo ' rte'
    endif
  endcapture
%}

<div 
  class="text-block {{ text_block_classes }} text-{{ block_settings.alignment }} {{ block_settings.type_preset | default: 'paragraph' }} spacing-style border-style"
  data-block-id="{{ block.id }}"
  data-product-id="{{ product_resource.id }}"
  style="
    {% render 'typography-style', settings: block_settings %}
    {% render 'spacing-style', settings: block_settings %}
    --width: {{ block_settings.width }};
  "
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="link payment-trigger-btn{% if block_settings.background %} payment-background{% endif %} border-style"
    on:click="#payment-modal/showDialog"
    aria-haspopup="dialog"
    style="      
      {% render 'border-override', settings: block_settings %}
      {% if block_settings.background %}
        --text-background-color: {{ block_settings.background_color | default: 'rgb(255 255 255 / 1.0)' }};
      {% endif %}
    "
  >
    <span>
        {{- 'icon-plus.svg' | inline_asset_content -}}
    </span> {{ 'flamma.payment_options' | t }}
  </button>
</div>

{% render 'payment-modal', 
   settings: block.settings, 
   unique_id: block.id,
   product: product_resource
%}

{% stylesheet %}
  .payment-trigger-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: transparent; 
    color: currentColor; 
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    padding: max(var(--padding-2xs) + var(--padding-xs) * (1 - cos(45deg)));
    min-height: 40px !important;
    height: 40px !important;
  }

  .payment-trigger-btn:hover {
    opacity: 0.8;
    color: var(--color-foreground) !important;
  }
  
  .payment-trigger-btn:active {
    transform: scale(0.98);
  }

  .payment-trigger-btn svg {
    width: 12px;
    height: 12px;
  }

  .payment-background {
    background-color: var(--text-background-color);
  }
  
  button.link.payment-trigger-btn.payment-background.border-style{
    height: 40px !important;
  }
{% endstylesheet %}

